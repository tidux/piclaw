{
  "name": "piclaw",
  "version": "0.7.7",
  "description": "Personal pi coding agent assistant. Lightweight nanoclaw-style orchestrator using Bun and pi.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "piclaw": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "build:vendor": "bun build web/src/vendor/codemirror-entry.ts --target=browser --format=esm --minify --outfile web/static/js/vendor/codemirror.js",
    "build:web": "bun run build:vendor && mkdir -p web/static/js/utils web/static/js/components web/static/js/ui && cp web/src/app.ts web/static/js/app.js && cp web/src/api.ts web/static/js/api.js && cp web/src/markdown.ts web/static/js/markdown.js && for f in web/src/utils/*.ts; do cp \"$f\" \"web/static/js/utils/$(basename \"$f\" .ts).js\"; done && for f in web/src/components/*.ts; do cp \"$f\" \"web/static/js/components/$(basename \"$f\" .ts).js\"; done && for f in web/src/ui/*.ts; do cp \"$f\" \"web/static/js/ui/$(basename \"$f\" .ts).js\"; done",
    "test": "bun test --max-concurrency=1",
    "test:coverage": "bun test --max-concurrency=1 --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.56.2",
    "@simplewebauthn/server": "9.0.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "cron-parser": "5.5.0",
    "fflate": "0.8.2",
    "qrcode-terminal": "0.12.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/basic-setup": "^0.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@eslint/js": "10.0.1",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/bun": "1.3.9",
    "@types/qrcode-terminal": "0.12.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@uiw/codemirror-theme-github": "^4.25.7",
    "codemirror": "^6.0.2",
    "eslint": "10.0.2",
    "globals": "17.3.0",
    "typescript": "5.9.3"
  }
}
