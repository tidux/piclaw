{
  "name": "piclaw-runtime",
  "version": "1.5.7",
  "description": "Personal pi coding agent assistant. Lightweight nanoclaw-style orchestrator using Bun and pi.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "piclaw": "src/index.ts"
  },
  "files": [
    "src",
    "extensions",
    "skills",
    "web/static",
    "docs",
    "scripts",
    "vendor-manifests",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "build:vendor:mermaid": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/beautiful-mermaid.json",
    "build:vendor:codemirror": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/codemirror-editor.json",
    "build:vendor:preact-htm": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/preact-htm.json",
    "build:vendor:marked": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/marked-global.json",
    "build:vendor:katex": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/katex-global.json",
    "build:vendor:katex-assets": "bun run scripts/vendor-katex-css-fonts.ts",
    "build:vendor:terminal-fonts": "bun run scripts/vendor-firacode-nerd-font.ts",
    "build:vendor:ghostty-web": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/ghostty-web.json",
    "build:vendor:zetajs": "bun run scripts/build-vendored-dependency.ts --manifest vendor-manifests/zetajs.json",
    "build:vendor:zetaoffice-wasm": "bun run scripts/vendor-zetaoffice-wasm.ts",
    "build:vendor:office-viewer": "bun run scripts/vendor-office-viewer.ts",
    "build:vendor:drawio": "bun run scripts/vendor-drawio.ts",
    "build:vendor": "bun run build:vendor:mermaid && bun run build:vendor:codemirror && bun run build:vendor:preact-htm && bun run build:vendor:marked && bun run build:vendor:katex && bun run build:vendor:katex-assets && bun run build:vendor:terminal-fonts && bun run build:vendor:ghostty-web && bun run build:vendor:office-viewer",
    "update:vendor:mermaid": "bun run scripts/update-vendored-dependency.ts --manifest vendor-manifests/beautiful-mermaid.json",
    "build:web": "bun run build:vendor && rm -rf web/static/dist && mkdir -p web/static/dist && bun build web/src/app.ts web/src/login.ts --target=browser --format=esm --minify --sourcemap --outdir web/static/dist --entry-naming=\"[name].bundle.js\" && bun build extensions/editor/editor-extension.ts --target=browser --format=esm --minify --sourcemap --external /editor-vendor/codemirror.js --outdir web/static/dist --entry-naming=\"editor.bundle.js\" && bun build web/src/styles/app.css web/src/styles/login.css --target=browser --minify --sourcemap --outdir web/static/dist --entry-naming=\"[name].bundle.css\" && rm -rf web/static/js/components web/static/js/utils web/static/js/ui && rm -f web/static/js/app.js web/static/js/api.js web/static/js/markdown.js && bun run scripts/stamp-cache-buster.ts",
    "test": "PICLAW_DB_IN_MEMORY=1 bun test --max-concurrency=1",
    "test:coverage": "PICLAW_DB_IN_MEMORY=1 bun test --max-concurrency=1 --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:optional:browser-isolation": "PICLAW_DB_IN_MEMORY=1 PICLAW_RUN_OPTIONAL_BROWSER_TESTS=1 bun test --max-concurrency=1 --timeout=30000 test/channels/web/browser-chat-isolation.optional.test.ts",
    "check:pack-hygiene": "bun run scripts/pack-hygiene.ts",
    "check:stale-dist": "bun run scripts/check-stale-dist.ts",
    "check:import-boundaries": "bun run scripts/check-import-boundaries.ts",
    "check:unused-exports": "bun run scripts/check-unused-exports.ts",
    "check:hook-tdz": "bun run scripts/check-hook-tdz.ts",
    "quality": "bun run lint && bun run typecheck && bun run test && bun run check:pack-hygiene && bun run check:stale-dist && bun run check:import-boundaries && bun run check:unused-exports && bun run check:hook-tdz"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lezer/highlight": "1.2.3",
    "@mariozechner/pi-coding-agent": "0.60.0",
    "@simplewebauthn/server": "13.2.3",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "adaptivecards": "3.0.5",
    "beautiful-mermaid": "1.1.3",
    "chart.js": "^4.5.1",
    "cron-parser": "5.5.0",
    "docx-preview": "^0.3.7",
    "fflate": "0.8.2",
    "ghostty-web": "github:rcarmo/ghostty-web#fcc47d423a7fce1c02c702b6464d0b1ab89175f1",
    "htm": "3.1.1",
    "katex": "0.16.38",
    "marked": "17.0.4",
    "pptxviewjs": "^1.1.8",
    "preact": "10.29.0",
    "qrcode-terminal": "0.12.0",
    "xlsx": "^0.18.5",
    "zetajs": "1.2.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "6.20.1",
    "@codemirror/basic-setup": "0.20.0",
    "@codemirror/commands": "6.10.2",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-go": "6.0.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.2",
    "@codemirror/language": "6.12.2",
    "@codemirror/legacy-modes": "6.5.2",
    "@codemirror/lint": "6.9.5",
    "@codemirror/search": "6.6.0",
    "@codemirror/state": "6.5.4",
    "@codemirror/view": "6.39.16",
    "@eslint/js": "10.0.1",
    "@replit/codemirror-indentation-markers": "6.5.3",
    "@replit/codemirror-vim": "6.3.0",
    "@types/bun": "1.3.10",
    "@types/qrcode-terminal": "0.12.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@uiw/codemirror-theme-github": "4.25.7",
    "codemirror": "6.0.2",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "playwright": "^1.58.2",
    "ts-prune": "^0.10.3",
    "typescript": "5.9.3"
  },
  "x-dependency-policy": "Pinned exact versions only (no ^/~ ranges)."
}
